# ══════════════════════════════════════════════════════
# Environment Variables — Prode MagIA
# ══════════════════════════════════════════════════════

# ─── Frontend (Front/.env) ───────────────────────────
VITE_SUPABASE_URL="https://tu-proyecto.supabase.co"
VITE_SUPABASE_ANON_KEY="tu_anon_key"

# ─── Backend (API/.env or root .env) ─────────────────
SUPABASE_URL="https://tu-proyecto.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="tu_service_role_key"
API_SPORTS_KEY="tu_api_football_key"
LEAGUE_ID=1
SEASON=2026
PORT=3005

# ─── Security ────────────────────────────────────────
# Separate secret for the /api/sync-matches endpoint.
# Do NOT reuse the SUPABASE_SERVICE_ROLE_KEY here.
API_SYNC_SECRET="genera_un_secret_aleatorio_aqui"

# Comma-separated list of allowed CORS origins
CORS_ORIGINS="http://localhost:3000,http://localhost:5173,https://tu-dominio-produccion.com"
